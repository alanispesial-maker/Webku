<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI TRADING ELITE</title>

<style>
body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: radial-gradient(circle at top, #0a0f1f, #02040a);
  color: #e5e7eb;
  display: flex;
  justify-content: center;
}

.app {
  width: 100%;
  max-width: 420px;
}

/* HEADER */
header {
  text-align: center;
  padding: 14px;
  font-weight: bold;
  background: rgba(15, 23, 42, 0.7);
  backdrop-filter: blur(10px);
}

.live {
  color: #ef4444;
  animation: blink 1s infinite;
}

@keyframes blink {
  50% { opacity: 0; }
}

/* BOX */
.box {
  margin: 12px;
  padding: 14px;
  border-radius: 14px;
  background: rgba(15, 23, 42, 0.6);
  backdrop-filter: blur(12px);
  box-shadow: 0 0 15px rgba(34, 197, 94, 0.15);
}

/* SIGNAL */
.signal {
  text-align: center;
  padding: 16px;
  border-radius: 14px;
  background: #0f172a;
  box-shadow: 0 0 20px rgba(34, 197, 94, 0.4);
  animation: pulse 2s infinite;
}

@keyframes pulse {
  50% { transform: scale(1.03); }
}

.big {
  font-size: 26px;
  font-weight: bold;
}

.win { color: #22c55e; }
.loss { color: #ef4444; }

/* BUTTON */
.btn {
  background: #229ED9;
  border: none;
  padding: 14px;
  width: 100%;
  border-radius: 12px;
  color: white;
  font-weight: bold;
  font-size: 15px;
  cursor: pointer;
  margin-top: 12px;
}

/* POPUP */
#pop {
  position: fixed;
  bottom: 80px;
  left: 50%;
  transform: translateX(-50%);
  background: #020617;
  padding: 8px 14px;
  border-radius: 10px;
  font-size: 12px;
  border: 1px solid #22c55e;
  opacity: 0;
}

@keyframes up {
  0% { transform: translate(-50%, 40px); opacity: 0; }
  30% { opacity: 1; }
  100% { transform: translate(-50%, -40px); opacity: 0; }
}
</style>
</head>

<body>

<div class="app">

<header>
🤖 AI TRADING ELITE<br>
<span class="live">🔴 LIVE AI ACTIVE</span>
</header>

<div class="box">
💎 Status Engine: <span class="win">AKTIF</span>
</div>

<div class="box">
<h3>⚡ SINYAL AI</h3>
<div id="signal" class="signal">Memuat...</div>
</div>

<div class="box">
<h3>🎯 AREA ENTRY</h3>
<div id="entry"></div>
</div>

<div class="box" style="text-align:center">
⚡ AKSES VIP DIPERLUKAN ⚡<br>

<button class="btn" onclick="joinTelegram()">
🚀 MASUK TELEGRAM VIP
</button>

<div style="font-size:12px;opacity:0.7;margin-top:6px">
⚡ trader global sudah bergabung
</div>

</div>

</div>

<div id="pop"></div>

<script>
function generate() {
  let price = 2000 + Math.random() * 100;
  let type = Math.random() > 0.5 ? "BUY" : "SELL";

  let tp = (type === "BUY" ? price + 30 : price - 30).toFixed(2);
  let sl = (type === "BUY" ? price - 20 : price + 20).toFixed(2);

  let entryLow = (price - 1).toFixed(2);
  let entryHigh = (price + 1).toFixed(2);

  document.getElementById("signal").innerHTML = `
    <div class="big">${type === "BUY" ? "🟢 BUY 🚀" : "🔴 SELL ⚡"}</div><br>
    TP: <span class="win">${tp}</span><br>
    SL: <span class="loss">${sl}</span>
  `;

  document.getElementById("entry").innerHTML =
    `<b>${entryLow} - ${entryHigh}</b>`;

  showProfit();
}

function showProfit() {
  let p = Math.floor(1000 + Math.random() * 50000);
  let el = document.getElementById("pop");

  el.innerHTML = `🔥 PROFIT $${p}`;
  el.style.animation = "none";
  void el.offsetWidth;
  el.style.animation = "up 2s ease forwards";
}

function joinTelegram() {
  window.location.href = "https://t.me/Fandxau17";
}

generate();
setInterval(generate, 5000);
</script>

</body>
</html>
